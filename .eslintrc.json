{
  "env": {
    "es6": true
  },
  "globals": {
    "SpreadsheetApp": "readonly",
    "DriveApp": "readonly",
    "DocumentApp": "readonly",
    "GmailApp": "readonly",
    "HtmlService": "readonly",
    "ContentService": "readonly",
    "UrlFetchApp": "readonly",
    "PropertiesService": "readonly",
    "CacheService": "readonly",
    "LockService": "readonly",
    "Session": "readonly",
    "ScriptApp": "readonly",
    "Utilities": "readonly",
    "Logger": "readonly",
    "Browser": "readonly",
    "MailApp": "readonly",
    "CalendarApp": "readonly"
  },
  "rules": {
    "semi": ["error", "always"],
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "eqeqeq": ["error", "always"],
    "no-console": "warn"
  },
  "parserOptions": {
    "ecmaVersion": 2019
  }
}
